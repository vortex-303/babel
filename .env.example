# babel — local translation service
# Copy to .env and adjust

# Server
BABEL_HOST=127.0.0.1
BABEL_PORT=8765

# Paths (relative to repo root)
BABEL_DATA_DIR=./jobs
BABEL_UPLOADS_DIR=./uploads
BABEL_OUTPUTS_DIR=./outputs
BABEL_SQLITE_PATH=./jobs/babel.sqlite

# Model adapter: llamacpp | ollama | gemini | claude
BABEL_MODEL_ADAPTER=llamacpp

# llama.cpp local inference
BABEL_LLAMACPP_HOST=127.0.0.1
BABEL_LLAMACPP_PORT=8080
BABEL_LLAMACPP_MODEL=translategemma-4b-it.Q4_K_M.gguf

# Cloud fallbacks (optional)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Translation defaults
BABEL_SOURCE_LANG=en
BABEL_TARGET_LANG=es
BABEL_CHUNK_TOKENS=1500
# 0 = non-overlapping source chunks (cleaner output assembly).
# Cross-chunk coherence comes from BABEL_CONTEXT_CHARS of the previous
# translated chunk being fed as "reference only" to the next translation.
BABEL_CHUNK_OVERLAP=0
BABEL_CONTEXT_CHARS=600
