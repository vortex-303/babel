# babel — local translation service
# Copy to .env and adjust

# Server
BABEL_HOST=127.0.0.1
BABEL_PORT=8765

# Paths (relative to repo root)
BABEL_DATA_DIR=./jobs
BABEL_UPLOADS_DIR=./uploads
BABEL_OUTPUTS_DIR=./outputs
BABEL_SQLITE_PATH=./jobs/babel.sqlite

# Model adapter: llamacpp | ollama | gemini | claude
BABEL_MODEL_ADAPTER=llamacpp

# llama.cpp local inference
BABEL_LLAMACPP_HOST=127.0.0.1
BABEL_LLAMACPP_PORT=8080
BABEL_LLAMACPP_MODEL=translategemma-4b-it.Q4_K_M.gguf

# Cloud fallbacks (optional)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Translation defaults
BABEL_SOURCE_LANG=en
BABEL_TARGET_LANG=es
BABEL_CHUNK_TOKENS=1500
# 0 = non-overlapping source chunks (cleaner output assembly).
# Cross-chunk coherence comes from BABEL_CONTEXT_CHARS of the previous
# translated chunk being fed as "reference only" to the next translation.
BABEL_CHUNK_OVERLAP=0
BABEL_CONTEXT_CHARS=600

# --- Admin + queue + limits ---
# Shared pass-code required for all /admin/* routes and for the frontend
# user menu "Sign in" button. Leave empty to disable admin endpoints entirely.
BABEL_ADMIN_CODE=

# Bearer token required by /api/worker/* endpoints. Leave empty to disable
# the worker endpoints entirely (e.g. pure local dev).
BABEL_WORKER_TOKEN=

# Worker-side only (babel-worker CLI, not the backend). Default on:
# users trigger translations from the website, the worker just drains.
# Flip to "false" if you want explicit claim-per-job from the CLI.
BABEL_WORKER_AUTO_CLAIM=true

# Set to 1 only when running locally alongside llama-server so the
# in-process queue worker can pick up jobs. On Fly/production leave off —
# the pull-worker (worker/) is the production path.
BABEL_INPROC_WORKER=0

# Queue mode: auto (default) = new jobs queued immediately; manual = non-admin
# jobs wait for admin approval in the /admin panel.
BABEL_QUEUE_MODE=auto
BABEL_QUEUE_INTERVAL_SECONDS=3

# Non-admin hard caps — admin bypasses. Tuned for ~3 full-sized books.
BABEL_MAX_UPLOAD_MB_NONADMIN=30         # ~500-page PDF with images
BABEL_MAX_WORD_COUNT_NONADMIN=200000    # ~600-page novel
BABEL_MAX_DOCUMENTS_NONADMIN=3          # 3 concurrent books in the system

# Days to keep documents before admin purge cleans them up.
BABEL_RETENTION_DAYS=7

# Watchdog — fail any TRANSLATING job that hasn't made a chunk commit in N
# minutes.
BABEL_WATCHDOG_STUCK_MINUTES=10
BABEL_WATCHDOG_INTERVAL_SECONDS=60

# Optional Sentry DSN. Leave empty to disable.
BABEL_SENTRY_DSN=

# --- Cloud mode (all empty = fully local) ---
# Postgres connection string. When set, overrides the SQLite default.
# Format (Supabase):
#   postgresql://postgres:<pw>@db.<ref>.supabase.co:5432/postgres?sslmode=require
BABEL_DATABASE_URL=

# Supabase Storage — used only when BOTH url and service_key are set.
# When empty, files go to local disk (BABEL_UPLOADS_DIR).
BABEL_SUPABASE_URL=
BABEL_SUPABASE_SERVICE_KEY=
BABEL_STORAGE_BUCKET=babel
